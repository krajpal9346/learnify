PORT=5000
NODE_ENV=development

# Local only: "memory" spins up an in-memory MongoDB (data wiped on restart).
# Production (Render): MUST use MongoDB Atlas — memory mode is blocked when NODE_ENV=production.
# Example Atlas URI:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/learnify?retryWrites=true&w=majority
MONGODB_URI=memory

JWT_SECRET=learnify_dev_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d
COOKIE_NAME=learnify_token

# Primary frontend origin (no trailing slash)
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# Optional: extra allowed origins, comma-separated (staging, custom domains, etc.)
# CLIENT_URLS=https://staging.example.com,https://learnify.example.com
# Note: *.vercel.app preview deploys are allowed automatically by CORS.
